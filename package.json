{
  "name": "anton-life-os",
  "version": "0.1.0",
  "private": true,
  "description": "Lokales, persönliches Life OS für Studium, Arbeit, Projekte und Alltag.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  },
  "scripts": {
    "env:check": "bash scripts/check-local-environment.sh",
    "db:start": "bash scripts/start-database.sh",
    "db:check": "bash scripts/check-database.sh",
    "db:stop": "bash scripts/stop-database.sh",
    "db:validate": "npm run db:validate --workspace @lifeos/database",
    "db:generate": "npm run db:generate --workspace @lifeos/database",
    "db:migrate": "npm run db:migrate:deploy --workspace @lifeos/database",
    "db:seed": "npm run db:seed --workspace @lifeos/database",
    "db:test": "npm test --workspace @lifeos/database",
    "api:dev": "npm run dev --workspace @lifeos/api",
    "api:start": "npm run start --workspace @lifeos/api",
    "auth:bootstrap": "npm run auth:bootstrap --workspace @lifeos/api",
    "caldav:bootstrap": "npm run caldav:bootstrap --workspace @lifeos/api",
    "caldav:revoke": "npm run caldav:revoke --workspace @lifeos/api",
    "build": "npm run db:generate && npm run build --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run lint --workspaces --if-present",
    "repo:check": "docker compose config --quiet",
    "test": "npm run test:repo && npm run test --workspaces --if-present",
    "test:repo": "node --test tests/*.test.mjs",
    "typecheck": "npm run db:generate && npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "prettier": "^3.6.2"
  }
}
