# Lokale Entwicklung mit ausschließlich synthetischen Beispielwerten.
# Vor dem ersten Start nach .env kopieren. Die lokale .env wird nie versioniert.
POSTGRES_DB=lifeos
POSTGRES_USER=lifeos
POSTGRES_PASSWORD=change-me-locally
POSTGRES_PORT=5432
DATABASE_URL=postgresql://lifeos:change-me-locally@localhost:5432/lifeos

# Spätere API-/CalDAV-Konfiguration
API_HOST=127.0.0.1
API_PORT=3000
WEB_ORIGIN=http://127.0.0.1:5173
LOG_LEVEL=info
SHUTDOWN_TIMEOUT_MS=10000
SESSION_TTL_HOURS=24
CALDAV_BASE_URL=http://localhost:3000/caldav
STORAGE_PATH=./data/documents

# Das einmalige Bootstrap-Passwort nur temporär in der Shell setzen, niemals
# hier eintragen oder committen: LIFEOS_BOOTSTRAP_PASSWORD
