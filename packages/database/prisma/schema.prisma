generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "esm"
  importFileExtension = "js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String          @id @default(uuid()) @db.Uuid
  externalId  String          @unique @db.VarChar(100)
  displayName String          @db.VarChar(200)
  createdAt   DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime        @updatedAt @db.Timestamptz(3)
  settings    UserSettings?
  credential  UserCredential?
  sessions    UserSession[]
  calendars   Calendar[]
  auditEvents AuditEvent[]
}

model UserSettings {
  userId              String   @id @db.Uuid
  timezone            String   @default("Europe/Berlin") @db.VarChar(100)
  currencyCode        String   @default("EUR") @db.Char(3)
  locale              String   @default("de-DE") @db.VarChar(35)
  weekStartsOn        Int      @default(1)
  defaultCalendarView String   @default("week") @db.VarChar(10)
  showWeekends        Boolean  @default(true)
  createdAt           DateTime @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime @updatedAt @db.Timestamptz(3)
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserCredential {
  userId       String   @id @db.Uuid
  passwordHash String   @db.VarChar(255)
  revision     Int      @default(1)
  createdAt    DateTime @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @db.Timestamptz(3)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSession {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @db.Uuid
  tokenHash          String    @unique @db.Char(64)
  credentialRevision Int
  expiresAt          DateTime  @db.Timestamptz(3)
  revokedAt          DateTime? @db.Timestamptz(3)
  createdAt          DateTime  @default(now()) @db.Timestamptz(3)
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, expiresAt])
}

model Calendar {
  id         String          @id @default(uuid()) @db.Uuid
  userId     String          @db.Uuid
  externalId String          @unique @db.VarChar(100)
  name       String          @db.VarChar(200)
  timezone   String          @default("Europe/Berlin") @db.VarChar(100)
  isPrimary  Boolean         @default(false)
  syncToken  Int             @default(0)
  createdAt  DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime        @updatedAt @db.Timestamptz(3)
  deletedAt  DateTime?       @db.Timestamptz(3)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  events     CalendarEvent[]

  @@unique([id, userId])
  @@index([userId, deletedAt])
}

model CalendarEvent {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @db.Uuid
  calendarId     String    @db.Uuid
  uid            String    @db.VarChar(255)
  title          String    @db.VarChar(500)
  description    String?
  location       String?   @db.VarChar(500)
  startsAt       DateTime? @db.Timestamptz(3)
  endsAt         DateTime? @db.Timestamptz(3)
  startDate      DateTime? @db.Date
  endDate        DateTime? @db.Date
  timezone       String    @default("Europe/Berlin") @db.VarChar(100)
  isAllDay       Boolean   @default(false)
  recurrenceRule String?   @db.Text
  etag           String    @db.VarChar(100)
  sequence       Int       @default(0)
  deletedAt      DateTime? @db.Timestamptz(3)
  createdAt      DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(3)
  calendar       Calendar  @relation(fields: [calendarId, userId], references: [id, userId], onDelete: Cascade)

  @@unique([calendarId, uid])
  @@index([userId, deletedAt])
  @@index([calendarId, startsAt])
  @@index([calendarId, startDate])
  @@index([calendarId, deletedAt])
}

model AuditEvent {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  action     String   @db.VarChar(100)
  entityType String   @db.VarChar(100)
  entityId   String?  @db.VarChar(100)
  metadata   Json?
  occurredAt DateTime @default(now()) @db.Timestamptz(3)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
  @@index([entityType, entityId])
}
